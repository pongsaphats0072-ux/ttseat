<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ระบบจองที่นั่ง</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@500;600;700&family=Kanit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="/socket.io/socket.io.js"></script>
  <style>
    :root {
      color-scheme: light;
      --font-body: "Kanit", "Segoe UI", sans-serif;
      --font-display: "Chakra Petch", "Kanit", sans-serif;
      --bg-color: #f6f2ec;
      --surface: rgba(255, 255, 255, 0.92);
      --surface-strong: #ffffff;
      --text-primary: #1f2933;
      --text-secondary: #52606d;
      --primary: #0f766e;
      --primary-strong: #0d9488;
      --accent: #f97316;
      --accent-strong: #ea580c;
      --danger: #ef4444;
      --border: rgba(15, 118, 110, 0.18);
      --shadow-sm: 0 8px 24px rgba(15, 118, 110, 0.12);
      --shadow-md: 0 18px 40px rgba(15, 118, 110, 0.18);
      --radius-sm: 0.6rem;
      --radius-md: 0.9rem;
      --radius-lg: 1.3rem;
      --radius-xl: 1.8rem;
      --bg-gradient:
        radial-gradient(800px 500px at 5% -10%, rgba(249, 115, 22, 0.25), transparent 60%),
        radial-gradient(700px 500px at 95% 10%, rgba(14, 165, 233, 0.18), transparent 60%),
        linear-gradient(120deg, #fdf6ef 0%, #f6f7fb 55%, #eef7f2 100%);
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: var(--font-body);
      background-color: var(--bg-color);
      background: var(--bg-gradient);
      color: var(--text-primary);
      min-height: 100vh;
      line-height: 1.6;
    }

    body::after {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      background-image: radial-gradient(rgba(15, 118, 110, 0.12) 1px, transparent 1px);
      background-size: 32px 32px;
      opacity: 0.35;
      z-index: -1;
    }

    .app-shell {
      max-width: 1280px;
      margin: 0 auto;
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-xl);
      padding: 1.5rem;
      box-shadow: var(--shadow-sm);
      backdrop-filter: blur(16px);
    }

    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 0.9rem;
    }

    .brand-mark {
      width: 48px;
      height: 48px;
      border-radius: 16px;
      background: linear-gradient(135deg, var(--primary), var(--accent));
      color: #fff;
      font-family: var(--font-display);
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: var(--shadow-sm);
    }

    .brand-title {
      font-family: var(--font-display);
      font-size: 1.4rem;
      font-weight: 700;
      letter-spacing: 0.02em;
    }

    .brand-sub {
      color: var(--text-secondary);
      font-size: 0.85rem;
    }

    .top-actions {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    .status-pill {
      padding: 0.35rem 0.8rem;
      border-radius: 999px;
      background: rgba(15, 118, 110, 0.1);
      color: var(--primary);
      font-weight: 600;
      font-size: 0.85rem;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 0.6rem 1.1rem;
      border-radius: 999px;
      border: 1px solid transparent;
      font-weight: 600;
      cursor: pointer;
      transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    }

    .btn-primary {
      background: linear-gradient(135deg, var(--primary), var(--primary-strong));
      color: #fff;
      box-shadow: var(--shadow-sm);
    }

    .btn-primary:hover {
      transform: translateY(-1px);
      box-shadow: var(--shadow-md);
    }

    .btn-outline {
      background: transparent;
      border-color: var(--border);
      color: var(--text-primary);
    }

    .btn-outline:hover {
      background: rgba(15, 118, 110, 0.08);
    }

    .hero {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1.5rem;
      flex-wrap: wrap;
    }

    .hero h1 {
      font-family: var(--font-display);
      font-size: clamp(1.8rem, 2.4vw, 2.6rem);
      margin-bottom: 0.4rem;
    }

    .hero p {
      color: var(--text-secondary);
    }

    .hero-steps {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    .notice-banner {
      background: #fff8e8;
      border: 1px solid rgba(146, 64, 14, 0.18);
      color: #7c2d12;
      border-radius: var(--radius-lg);
      padding: 0.85rem 1rem;
      font-size: 0.92rem;
      line-height: 1.5;
    }

    .step-chip {
      background: var(--surface-strong);
      border: 1px dashed var(--border);
      padding: 0.4rem 0.7rem;
      border-radius: 999px;
      font-size: 0.85rem;
      color: var(--text-secondary);
      font-weight: 500;
    }

    .board-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 1rem;
      flex-wrap: wrap;
    }

    .board-title {
      font-family: var(--font-display);
      font-size: 1.3rem;
    }

    .legend {
      display: flex;
      gap: 0.6rem;
      flex-wrap: wrap;
    }

    .legend-item {
      display: flex;
      align-items: center;
      gap: 0.35rem;
      font-size: 0.8rem;
      color: var(--text-secondary);
    }

    .legend-dot {
      width: 10px;
      height: 10px;
      border-radius: 999px;
    }

    .dot-available {
      background: linear-gradient(135deg, #0f766e, #22c1c3);
    }

    .dot-booked {
      background: linear-gradient(135deg, #ef4444, #f97316);
    }

    .dot-selected {
      background: linear-gradient(135deg, #0ea5e9, #0f766e);
    }

    .stage-row {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      margin: 0.5rem 0 1.2rem;
      flex-wrap: wrap;
    }

    .stage {
      background: #111827;
      color: #fff;
      padding: 0.6rem 1.4rem;
      border-radius: 999px;
      font-weight: 700;
      font-size: 0.9rem;
    }

    .teacher {
      background: #fff3c4;
      color: #92400e;
      border: 1px solid rgba(249, 115, 22, 0.4);
      padding: 0.5rem 1.2rem;
      border-radius: 999px;
      font-weight: 600;
      font-size: 0.9rem;
    }

    .label-row {
      display: flex;
      justify-content: space-between;
      color: var(--text-secondary);
      font-size: 0.8rem;
      font-weight: 600;
      margin: 0.4rem 0;
    }

    .seat-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.5rem;
    }

    .seat-block {
      border: 1px solid var(--border);
      border-radius: var(--radius-md);
      padding: 0.75rem;
      background: var(--surface-strong);
    }

    .block-title {
      text-align: center;
      font-weight: 600;
      color: var(--text-secondary);
      margin-bottom: 0.5rem;
      font-size: 0.85rem;
    }

    .seat {
      width: 100%;
      padding: 0.55rem 0;
      border-radius: 0.6rem;
      border: 1px solid rgba(15, 118, 110, 0.25);
      background: linear-gradient(135deg, #0f766e, #22c1c3);
      color: #fff;
      font-weight: 600;
      font-size: 0.8rem;
      transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease;
    }

    .seat:hover:not(.is-booked) {
      transform: translateY(-2px);
      box-shadow: 0 8px 16px rgba(15, 118, 110, 0.2);
    }

    .seat.is-booked {
      background: linear-gradient(135deg, #ef4444, #f97316);
      opacity: 0.7;
      cursor: not-allowed;
    }

    .seat.is-selected {
      outline: 3px solid rgba(14, 165, 233, 0.35);
      box-shadow: 0 0 0 6px rgba(14, 165, 233, 0.15);
    }

    .seat:disabled {
      cursor: not-allowed;
    }

    .layout-board {
      --seat-scale: 1;
      position: relative;
      min-height: 320px;
      border-radius: var(--radius-xl);
      overflow: hidden;
      background:
        radial-gradient(circle at 1px 1px, rgba(15, 118, 110, 0.1) 1px, transparent 0) 0 0 / 24px 24px,
        rgba(255, 255, 255, 0.55);
      border: 1px solid var(--border);
    }

    .layout-scroll {
      overflow: auto;
      max-width: 100%;
    }

    .layout-scroll {
      overflow: auto;
      max-width: 100%;
    }

    .floating-seat {
      position: absolute;
      width: calc(138px * var(--seat-scale));
      min-height: calc(96px * var(--seat-scale));
      border-radius: calc(16px * var(--seat-scale));
      box-shadow: 0 10px 24px rgba(15, 118, 110, 0.16);
      font-size: calc(0.8rem * var(--seat-scale));
    }

    .floating-seat small {
      display: block;
      margin-top: 0.2rem;
      font-size: calc(0.62rem * var(--seat-scale));
      opacity: 0.9;
      word-break: break-word;
    }

    .layout-empty {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 180px;
      color: var(--text-secondary);
      border: 1px dashed var(--border);
      border-radius: var(--radius-xl);
      background: rgba(255, 255, 255, 0.7);
    }

    .panel-stack {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .selected-seat {
      font-family: var(--font-display);
      font-size: 2.2rem;
      color: var(--primary);
    }

    .muted {
      color: var(--text-secondary);
      font-size: 0.9rem;
    }

    .stat-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.75rem;
    }

    .stat {
      padding: 0.75rem;
      border-radius: var(--radius-md);
      background: var(--surface-strong);
      border: 1px solid var(--border);
    }

    .stat-label {
      font-size: 0.8rem;
      color: var(--text-secondary);
    }

    .stat-value {
      font-size: 1.3rem;
      font-weight: 700;
      color: var(--text-primary);
    }

    .booking-list {
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
      max-height: 260px;
      overflow: auto;
    }

    .booking-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 0.5rem;
      padding: 0.75rem;
      border-radius: var(--radius-md);
      background: var(--surface-strong);
      border: 1px solid var(--border);
    }

    .booking-seat {
      font-weight: 700;
      color: var(--primary);
    }

    .booking-time {
      font-size: 0.75rem;
      color: var(--text-secondary);
    }

    .modal {
      position: fixed;
      inset: 0;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
      z-index: 1000;
    }

    .modal.is-open {
      display: flex;
    }

    .modal-backdrop {
      position: absolute;
      inset: 0;
      background: rgba(15, 23, 42, 0.35);
      backdrop-filter: blur(4px);
    }

    .modal-card {
      position: relative;
      background: var(--surface-strong);
      border-radius: var(--radius-lg);
      padding: 1.5rem;
      width: min(420px, 92vw);
      border: 1px solid var(--border);
      box-shadow: var(--shadow-md);
      display: flex;
      flex-direction: column;
      gap: 1rem;
      z-index: 1;
      animation: pop 0.3s ease;
    }

    .modal-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
    }

    .icon-btn {
      border: none;
      background: rgba(15, 118, 110, 0.08);
      color: var(--primary);
      width: 36px;
      height: 36px;
      border-radius: 999px;
      cursor: pointer;
      font-weight: 700;
    }

    .modal-input {
      width: 100%;
      padding: 0.75rem 0.9rem;
      border-radius: var(--radius-md);
      border: 1px solid var(--border);
      background: #fff;
      font-size: 0.95rem;
    }

    .modal-input:focus {
      outline: none;
      border-color: var(--primary);
      box-shadow: 0 0 0 3px rgba(15, 118, 110, 0.18);
    }

    .modal-actions {
      display: flex;
      gap: 0.75rem;
    }

    .modal-actions .btn {
      flex: 1;
    }

    .notification {
      position: fixed;
      bottom: 1.5rem;
      right: 1.5rem;
      padding: 0.9rem 1.2rem;
      border-radius: 999px;
      color: #fff;
      font-weight: 600;
      box-shadow: var(--shadow-md);
      opacity: 0;
      transform: translateY(10px);
      transition: all 0.3s ease;
      z-index: 1200;
    }

    .notification.show {
      opacity: 1;
      transform: translateY(0);
    }

    .notification.success {
      background: linear-gradient(135deg, var(--primary), var(--primary-strong));
    }

    .notification.error {
      background: linear-gradient(135deg, #ef4444, #f97316);
    }

    .notification.info {
      background: linear-gradient(135deg, #0ea5e9, #0f766e);
    }

    @keyframes pop {
      from {
        opacity: 0;
        transform: translateY(10px) scale(0.98);
      }
      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    @media (max-width: 900px) {
      .topbar {
        flex-direction: column;
        align-items: flex-start;
      }

      .hero {
        flex-direction: column;
        align-items: flex-start;
      }

      .stat-grid {
        grid-template-columns: 1fr;
      }

      .label-row {
        font-size: 0.75rem;
      }
    }
  </style>
</head>
<body>
  <div class="app-shell">
    <header class="card topbar">
      <div class="brand">
        <div class="brand-mark">S</div>
        <div>
          <div class="brand-title">ระบบจองที่นั่ง</div>
        </div>
      </div>
      <div class="top-actions">
        <a class="btn btn-outline" href="/summary">📊 Summary</a>
        <a class="btn btn-outline" href="/admin-login">⚙️ Admin</a>
      </div>
    </header>

    <section class="card hero">
      <div>
        <h1>จองที่นั่งห้องเรียน</h1>
      </div>
      <div class="hero-steps">
        <div class="step-chip">1 เลือกที่นั่ง</div>
        <div class="step-chip">2 ใส่ชื่อเล่น</div>
        <div class="step-chip">3 กดยืนยัน</div>
      </div>
    </section>

    <section class="notice-banner">
      แจ้งเตือน: ระบบนี้พัฒนาแบบเร่งด่วนด้วย AI อาจมีข้อผิดพลาด หากพบข้อผิดพลาดโปรดติดต่อ TIKTOK:33student126 และระบบนี้ใช้งานได้ดีกว่าบน tablet, iPad และ PC
    </section>

    <main class="grid grid-cols-1 lg:grid-cols-[minmax(0,2fr)_minmax(0,1fr)] gap-6">
      <section class="card">
        <div class="board-header">
          <div>
            <div class="board-title">ผังที่นั่ง</div>
            <div class="muted">คลิกที่นั่งเพื่อจองทันที</div>
          </div>
          <div class="legend">
            <div class="legend-item"><span class="legend-dot dot-available"></span>ว่าง</div>
            <div class="legend-item"><span class="legend-dot dot-booked"></span>จองแล้ว</div>
            <div class="legend-item"><span class="legend-dot dot-selected"></span>ที่นั่งที่เลือก</div>
          </div>
        </div>

        <div class="layout-scroll">
          <div class="layout-board" id="classroomLayout"></div>
        </div>
      </section>

      <aside class="panel-stack">
        <div class="card">
          <div class="board-title">ที่นั่งที่เลือก</div>
          <div id="selectedSeatLabel" class="selected-seat">—</div>
          <p class="muted">คลิกที่นั่งด้านซ้ายเพื่อเลือก</p>
          <button id="openBookingBtn" class="btn btn-primary">ยืนยันการจอง</button>
        </div>

        <div class="card">
          <div class="board-title">สถานะที่นั่ง</div>
          <div class="stat-grid">
            <div class="stat">
              <div class="stat-label">ว่าง</div>
              <div class="stat-value" id="emptySeats">45</div>
            </div>
            <div class="stat">
              <div class="stat-label">จองแล้ว</div>
              <div class="stat-value" id="bookedSeats">0</div>
            </div>
          </div>
        </div>

        <div class="card">
          <div class="board-title">การจองล่าสุด</div>
          <div id="bookingsList" class="booking-list">
            <p class="muted">กำลังโหลด...</p>
          </div>
        </div>
      </aside>
    </main>
  </div>

  <div id="bookingModal" class="modal" aria-hidden="true">
    <div class="modal-backdrop" data-modal-close></div>
    <div class="modal-card">
      <div class="modal-header">
        <div>
          <div class="board-title">ยืนยันการจอง</div>
          <div class="muted">ที่นั่ง <span id="modalSeatValue">-</span></div>
        </div>
        <button class="icon-btn" data-modal-close aria-label="ปิด">✕</button>
      </div>
      <div>
        <label for="modalNickname" class="muted">ชื่อเล่น</label>
        <input id="modalNickname" class="modal-input" type="text" placeholder="เช่น โต้ง" />
      </div>
      <div class="modal-actions">
        <button class="btn btn-outline" data-modal-close id="modalCancelBtn">ยกเลิก</button>
        <button class="btn btn-primary" id="confirmBookingBtn">ยืนยันการจอง</button>
      </div>
    </div>
  </div>

  <div id="notification" class="notification"></div>

  <script>
    const socket = io();
    const classroomLayout = document.getElementById('classroomLayout');
    const selectedSeatLabel = document.getElementById('selectedSeatLabel');
    const openBookingBtn = document.getElementById('openBookingBtn');
    const modal = document.getElementById('bookingModal');
    const modalSeatValue = document.getElementById('modalSeatValue');
    const modalNickname = document.getElementById('modalNickname');
    const confirmBookingBtn = document.getElementById('confirmBookingBtn');
    const notification = document.getElementById('notification');

    const baseSeatCardWidth = 138;
    const baseSeatCardHeight = 96;
    const canvasPadding = 16;
    const defaultRoomSize = {
      width: 1400,
      height: 900
    };

    let bookings = [];
    let selectedSeat = null;
    let seatLayout = [];
    let seatPositions = {};
    let roomSize = { ...defaultRoomSize };
    let viewScale = 1;

    function getCanvasSize() {
      return { ...roomSize };
    }

    function clampRoomSize(nextRoomSize) {
      return {
        width: Math.max(960, Math.min(5000, Math.round(nextRoomSize.width))),
        height: Math.max(720, Math.min(3500, Math.round(nextRoomSize.height)))
      };
    }

    function applyRoomSize() {
      roomSize = clampRoomSize(roomSize);
      updateViewScale();
    }

    function updateViewScale() {
      const scrollContainer = classroomLayout.closest('.layout-scroll');
      const availableWidth = Math.max((scrollContainer ? scrollContainer.clientWidth : window.innerWidth) - 8, 280);
      const availableHeight = Math.max((window.innerWidth <= 768 ? window.innerHeight * 0.62 : window.innerHeight * 0.78), 280);
      const scaleByWidth = availableWidth / Math.max(roomSize.width, 1);
      const scaleByHeight = availableHeight / Math.max(roomSize.height, 1);

      viewScale = Math.max(0.32, Math.min(1.12, Math.min(scaleByWidth, scaleByHeight)));

      classroomLayout.style.width = `${Math.round(roomSize.width * viewScale)}px`;
      classroomLayout.style.height = `${Math.round(roomSize.height * viewScale)}px`;
      classroomLayout.style.setProperty('--seat-scale', String(viewScale));
    }

    function isValidPosition(position) {
      return position
        && Number.isFinite(position.x)
        && Number.isFinite(position.y);
    }

    function defaultPosition(index = 0) {
      const size = getCanvasSize();
      const centerX = Math.max((size.width - baseSeatCardWidth) / 2, canvasPadding);
      const centerY = Math.max((size.height - baseSeatCardHeight) / 2, canvasPadding);
      const offset = index * 24;

      return {
        x: Math.min(size.width - baseSeatCardWidth - canvasPadding, Math.max(canvasPadding, centerX + offset)),
        y: Math.min(size.height - baseSeatCardHeight - canvasPadding, Math.max(canvasPadding, centerY + offset))
      };
    }

    function normalizePositions(layout, positions) {
      const nextPositions = {};
      layout.forEach((seatId, index) => {
        const position = positions?.[seatId];
        nextPositions[seatId] = isValidPosition(position) ? position : defaultPosition(index);
      });
      return nextPositions;
    }

    function syncPositionsWithLayout() {
      seatPositions = normalizePositions(seatLayout, seatPositions);
    }

    function getBookingMap() {
      const bookingMap = {};
      bookings.forEach((booking) => {
        bookingMap[booking.seatId] = booking.nickname;
      });
      return bookingMap;
    }

    function renderClassroomLayout() {
      syncPositionsWithLayout();
      const bookingMap = getBookingMap();

      if (!seatLayout.length) {
        classroomLayout.innerHTML = '<div class="layout-empty">ผังยังว่างอยู่</div>';
        return;
      }

      classroomLayout.innerHTML = seatLayout.map((seatId, index) => {
        const position = seatPositions[seatId] || defaultPosition(index);
        const bookingName = bookingMap[seatId];
        const isSelected = selectedSeat === seatId;

        return `
          <button class="seat floating-seat ${bookingName ? 'is-booked' : 'is-available'} ${isSelected ? 'is-selected' : ''}" data-seat="${seatId}" style="left:${position.x * viewScale}px; top:${position.y * viewScale}px;" ${bookingName ? 'disabled' : ''}>
            <span style="font-weight: 700;">${seatId}</span>
            <small>${bookingName || 'ว่าง'}</small>
          </button>
        `;
      }).join('');
    }

    function setSelectedSeat(seatId) {
      selectedSeat = seatId;
      selectedSeatLabel.textContent = seatId || '—';
      updateUI();
    }

    function openModal() {
      if (!selectedSeat) {
        showNotification('โปรดเลือกที่นั่งก่อน', 'error');
        return;
      }

      modalSeatValue.textContent = selectedSeat;
      modal.classList.add('is-open');
      modal.setAttribute('aria-hidden', 'false');
      modalNickname.value = '';
      setTimeout(() => modalNickname.focus(), 50);
    }

    function closeModal() {
      modal.classList.remove('is-open');
      modal.setAttribute('aria-hidden', 'true');
    }

    function showNotification(message, type = 'info') {
      notification.textContent = message;
      notification.className = `notification ${type} show`;
      clearTimeout(notification.hideTimer);
      notification.hideTimer = setTimeout(() => {
        notification.classList.remove('show');
      }, 3000);
    }

    function updateUI() {
      const bookedSeats = new Set(bookings.map((booking) => booking.seatId));
      const totalSeats = seatLayout.length;
      const emptyCount = Math.max(totalSeats - bookedSeats.size, 0);

      document.getElementById('bookedSeats').textContent = bookedSeats.size;
      document.getElementById('emptySeats').textContent = emptyCount;

      if (selectedSeat && bookedSeats.has(selectedSeat)) {
        selectedSeat = null;
        selectedSeatLabel.textContent = '—';
      }

      renderClassroomLayout();
    }

    function displayBookingsList() {
      const listContainer = document.getElementById('bookingsList');
      if (bookings.length === 0) {
        listContainer.innerHTML = '<p class="muted">ยังไม่มีการจอง</p>';
        return;
      }

      const sorted = [...bookings].sort((a, b) => new Date(b.timestamp) - new Date(a.timestamp));
      listContainer.innerHTML = sorted
        .map((booking) => {
          const time = new Date(booking.timestamp).toLocaleTimeString('th-TH');
          return `
            <div class="booking-item">
              <div>
                <div class="booking-seat">${booking.seatId} · ${booking.nickname}</div>
                <div class="booking-time">${time}</div>
              </div>
              <span class="status-pill">จองแล้ว</span>
            </div>
          `;
        })
        .join('');
    }

    function loadBookings() {
      fetch('/api/bookings')
        .then((response) => response.json())
        .then((data) => {
          bookings = data;
          updateUI();
          displayBookingsList();
        })
        .catch((error) => console.error('Error loading bookings:', error));
    }

    async function loadLayout() {
      try {
        const response = await fetch('/api/layout');
        const data = await response.json();
        seatLayout = Array.isArray(data.seats) ? data.seats : [];
        seatPositions = data.positions && typeof data.positions === 'object' && !Array.isArray(data.positions)
          ? data.positions
          : {};
        roomSize = data.roomSize && typeof data.roomSize === 'object' && !Array.isArray(data.roomSize)
          ? data.roomSize
          : { ...defaultRoomSize };
        applyRoomSize();
        syncPositionsWithLayout();
      } catch (error) {
        console.error('Error loading layout:', error);
        seatLayout = [];
        seatPositions = {};
        roomSize = { ...defaultRoomSize };
        applyRoomSize();
      }

      renderClassroomLayout();
    }

    classroomLayout.addEventListener('click', (event) => {
      const button = event.target.closest('.seat');
      if (!button) {
        return;
      }

      if (button.disabled) {
        showNotification('ที่นั่งนี้ถูกจองแล้ว', 'error');
        return;
      }

      setSelectedSeat(button.dataset.seat);
      openModal();
    });

    socket.on('load-bookings', (data) => {
      bookings = data;
      updateUI();
      displayBookingsList();
    });

    socket.on('booking-success', (data) => {
      bookings.push({
        seatId: data.seatId,
        nickname: data.nickname,
        timestamp: data.timestamp
      });
      updateUI();
      displayBookingsList();
      showNotification('จองที่นั่งสำเร็จ: ' + data.seatId, 'success');
      setSelectedSeat(null);
    });

    socket.on('booking-failed', (data) => {
      showNotification(data.message + ' (' + data.seatId + ')', 'error');
    });

    socket.on('cancel-success', (data) => {
      bookings = bookings.filter((booking) => booking.seatId !== data.seatId);
      updateUI();
      displayBookingsList();
    });

    socket.on('layout-updated', (data) => {
      if (!data || typeof data !== 'object') {
        return;
      }

      seatLayout = Array.isArray(data.seats) ? data.seats : [];
      seatPositions = data.positions && typeof data.positions === 'object' && !Array.isArray(data.positions)
        ? data.positions
        : {};
      roomSize = data.roomSize && typeof data.roomSize === 'object' && !Array.isArray(data.roomSize)
        ? data.roomSize
        : { ...defaultRoomSize };
      applyRoomSize();
      syncPositionsWithLayout();
      updateUI();
      displayBookingsList();
    });

    openBookingBtn.addEventListener('click', openModal);

    confirmBookingBtn.addEventListener('click', () => {
      const nickname = modalNickname.value.trim();

      if (!selectedSeat) {
        showNotification('โปรดเลือกที่นั่งก่อน', 'error');
        return;
      }

      if (!nickname) {
        showNotification('โปรดใส่ชื่อเล่น', 'error');
        modalNickname.focus();
        return;
      }

      socket.emit('book-seat', {
        seatId: selectedSeat,
        nickname
      });

      closeModal();
    });

    modalNickname.addEventListener('keydown', (event) => {
      if (event.key === 'Enter') {
        event.preventDefault();
        confirmBookingBtn.click();
      }
    });

    document.querySelectorAll('[data-modal-close]').forEach((button) => {
      button.addEventListener('click', closeModal);
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && modal.classList.contains('is-open')) {
        closeModal();
      }
    });

    window.addEventListener('resize', () => {
      updateViewScale();
      renderClassroomLayout();
    });

    loadBookings();
    loadLayout();
  </script>
</body>
</html>
