<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>สรุปที่นั่ง | SeatFlow</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@500;600;700&family=Kanit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    :root {
      --font-body: "Kanit", "Segoe UI", sans-serif;
      --font-display: "Chakra Petch", "Kanit", sans-serif;
      --bg-color: #f6f2ec;
      --surface: rgba(255, 255, 255, 0.92);
      --surface-strong: #ffffff;
      --text-primary: #1f2933;
      --text-secondary: #52606d;
      --primary: #0f766e;
      --primary-strong: #0d9488;
      --accent: #f97316;
      --border: rgba(15, 118, 110, 0.18);
      --shadow-sm: 0 8px 24px rgba(15, 118, 110, 0.12);
      --shadow-md: 0 18px 40px rgba(15, 118, 110, 0.18);
      --radius-xl: 1.8rem;
      --bg-gradient:
        radial-gradient(800px 500px at 5% -10%, rgba(249, 115, 22, 0.25), transparent 60%),
        radial-gradient(700px 500px at 95% 10%, rgba(14, 165, 233, 0.18), transparent 60%),
        linear-gradient(120deg, #fdf6ef 0%, #f6f7fb 55%, #eef7f2 100%);
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: var(--font-body);
      background-color: var(--bg-color);
      background: var(--bg-gradient);
      color: var(--text-primary);
      min-height: 100vh;
      line-height: 1.6;
    }

    body::after {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      background-image: radial-gradient(rgba(15, 118, 110, 0.12) 1px, transparent 1px);
      background-size: 32px 32px;
      opacity: 0.35;
      z-index: -1;
    }

    .app-shell {
      max-width: 1200px;
      margin: 0 auto;
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-xl);
      padding: 1.5rem;
      box-shadow: var(--shadow-sm);
      backdrop-filter: blur(16px);
    }

    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 0.9rem;
    }

    .brand-mark {
      width: 48px;
      height: 48px;
      border-radius: 16px;
      background: linear-gradient(135deg, var(--primary), var(--accent));
      color: #fff;
      font-family: var(--font-display);
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: var(--shadow-sm);
    }

    .brand-title {
      font-family: var(--font-display);
      font-size: 1.4rem;
      font-weight: 700;
    }

    .brand-sub {
      color: var(--text-secondary);
      font-size: 0.85rem;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 0.6rem 1.1rem;
      border-radius: 999px;
      border: none;
      font-weight: 600;
      cursor: pointer;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
      font-family: var(--font-body);
      text-decoration: none;
    }

    .btn-primary {
      background: linear-gradient(135deg, var(--primary), var(--primary-strong));
      color: #fff;
      box-shadow: var(--shadow-sm);
    }

    .btn-primary:hover {
      transform: translateY(-1px);
      box-shadow: var(--shadow-md);
    }

    .btn-outline {
      background: transparent;
      border: 1px solid var(--border);
      color: var(--text-primary);
    }

    .btn-outline:hover {
      background: rgba(15, 118, 110, 0.08);
    }

    .hero {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1.5rem;
      flex-wrap: wrap;
    }

    .hero h1 {
      font-family: var(--font-display);
      font-size: clamp(1.8rem, 2.4vw, 2.6rem);
      margin-bottom: 0.4rem;
    }

    .summary-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 1rem;
    }

    .seat-card {
      background: var(--surface-strong);
      border: 1px solid var(--border);
      border-radius: 0.9rem;
      padding: 1rem;
      text-align: center;
      box-shadow: var(--shadow-sm);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .seat-card:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-md);
    }

    .seat-id {
      font-family: var(--font-display);
      font-size: 1.8rem;
      font-weight: 700;
      background: linear-gradient(135deg, var(--primary), var(--primary-strong));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 0.5rem;
    }

    .seat-name {
      font-weight: 600;
      color: var(--text-primary);
      font-size: 0.95rem;
      word-break: break-word;
    }

    .seat-time {
      font-size: 0.75rem;
      color: var(--text-secondary);
      margin-top: 0.4rem;
    }

    .empty-state {
      text-align: center;
      padding: 3rem 1.5rem;
      color: var(--text-secondary);
    }

    .empty-state svg {
      width: 60px;
      height: 60px;
      margin: 0 auto 1rem;
      opacity: 0.4;
    }

    .actions {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    .muted {
      color: var(--text-secondary);
      font-size: 0.9rem;
    }

    .board-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 1rem;
      flex-wrap: wrap;
    }

    .board-title {
      font-family: var(--font-display);
      font-size: 1.3rem;
    }

    .legend {
      display: flex;
      gap: 0.6rem;
      flex-wrap: wrap;
    }

    .legend-item {
      display: flex;
      align-items: center;
      gap: 0.35rem;
      font-size: 0.8rem;
      color: var(--text-secondary);
    }

    .legend-dot {
      width: 10px;
      height: 10px;
      border-radius: 999px;
    }

    .dot-available {
      background: linear-gradient(135deg, #0f766e, #22c1c3);
    }

    .dot-booked {
      background: linear-gradient(135deg, #ef4444, #f97316);
    }

    .summary-board {
      margin-top: 1rem;
    }

    .summary-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 1rem;
    }

    .summary-seat {
      background: var(--surface-strong);
      border: 1px solid var(--border);
      border-radius: 1rem;
      padding: 1rem;
      box-shadow: var(--shadow-sm);
      text-align: center;
    }

    .summary-seat.is-booked {
      border-color: rgba(239, 68, 68, 0.28);
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(255, 241, 241, 0.96));
    }

    .summary-seat-id {
      font-family: var(--font-display);
      font-size: 1.7rem;
      font-weight: 700;
      color: var(--primary);
      margin-bottom: 0.35rem;
    }

    .summary-seat.is-booked .summary-seat-id {
      color: #dc2626;
    }

    .summary-seat-name {
      font-weight: 600;
      color: var(--text-primary);
      word-break: break-word;
    }

    .summary-seat-meta {
      color: var(--text-secondary);
      font-size: 0.75rem;
      margin-top: 0.35rem;
    }

    @media (max-width: 900px) {
      .summary-grid {
        grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
      }

      .topbar {
        flex-direction: column;
        align-items: flex-start;
      }

      .hero {
        flex-direction: column;
        align-items: flex-start;
      }

      .actions {
        width: 100%;
      }

      .actions .btn {
        flex: 1;
      }
    }
  </style>
</head>
<body>
  <div class="app-shell">
    <header class="card topbar">
      <div class="brand">
        <div class="brand-mark">S</div>
        <div>
          <div class="brand-title">SeatFlow</div>
          <div class="brand-sub">Booking Summary</div>
        </div>
      </div>
      <div class="actions">
        <a href="/" class="btn btn-outline">← กลับหน้าหลัก</a>
      </div>
    </header>

    <section class="card hero">
      <div>
        <h1>สรุปรายชื่อที่นั่งที่ถูกจอง</h1>
        <p class="muted">ทั้งหมด <strong id="totalBookings">0</strong> ที่นั่ง</p>
      </div>
    </section>

    <main class="card">
      <div class="board-header">
        <div>
          <div class="board-title">ผังที่นั่ง</div>
          <div class="muted">แสดงรายชื่อผู้จองแต่ละที่นั่ง</div>
        </div>
        <div class="legend">
          <div class="legend-item"><span class="legend-dot dot-available"></span>ว่าง</div>
          <div class="legend-item"><span class="legend-dot dot-booked"></span>จองแล้ว</div>
        </div>
      </div>

      <div class="summary-board" id="classroomSummary"></div>
    </main>

    <footer class="card" style="text-align: center; color: var(--text-secondary); font-size: 0.85rem;">
      <p>อัปเดตล่าสุด: <span id="lastUpdate">—</span></p>
    </footer>
  </div>

  <script src="/socket.io/socket.io.js"></script>
  <script>
    const classroomSummary = document.getElementById('classroomSummary');
    const socket = io();

    let seatLayout = [];
    let seatPositions = {};

    function renderSummaryLayout(bookings) {
      const bookingMap = {};
      bookings.forEach((booking) => {
        bookingMap[booking.seatId] = booking.nickname;
      });

      if (!seatLayout.length) {
        classroomSummary.innerHTML = '<div class="empty-state"><p>ผังยังว่างอยู่</p></div>';
        return;
      }

      classroomSummary.innerHTML = seatLayout.map((seatId) => {
        const bookedName = bookingMap[seatId];

        return `
          <div class="summary-seat ${bookedName ? 'is-booked' : ''}">
            <div class="summary-seat-id">${seatId}</div>
            <div class="summary-seat-name">${bookedName || 'ว่าง'}</div>
            <div class="summary-seat-meta">${bookedName ? 'จองแล้ว' : 'พร้อมใช้งาน'}</div>
          </div>
        `;
      }).join('');
    }

    async function loadLayout() {
      try {
        const response = await fetch('/api/layout');
        const data = await response.json();
        seatLayout = Array.isArray(data.seats) ? data.seats : [];
        seatPositions = data.positions && typeof data.positions === 'object' && !Array.isArray(data.positions)
          ? data.positions
          : {};
      } catch (error) {
        console.error('Error loading summary layout:', error);
        seatLayout = [];
        seatPositions = {};
      }
    }

    async function loadSummary() {
      try {
        const response = await fetch('/api/bookings');
        const bookings = await response.json();

        document.getElementById('totalBookings').textContent = bookings.length;
        renderSummaryLayout(bookings);

        const now = new Date();
        document.getElementById('lastUpdate').textContent = now.toLocaleTimeString('th-TH', {
          hour: '2-digit',
          minute: '2-digit',
          second: '2-digit'
        });
      } catch (error) {
        console.error('Error loading summary:', error);
      }
    }

    socket.on('booking-success', loadSummary);
    socket.on('cancel-success', loadSummary);
    socket.on('layout-updated', (data) => {
      if (!data || typeof data !== 'object') {
        return;
      }

      seatLayout = Array.isArray(data.seats) ? data.seats : [];
      seatPositions = data.positions && typeof data.positions === 'object' && !Array.isArray(data.positions)
        ? data.positions
        : {};
      loadSummary();
    });

    loadLayout().then(loadSummary);
  </script>
</body>
</html>
